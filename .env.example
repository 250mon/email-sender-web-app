# Frontend (Next.js) external port
FRONTEND_PORT=3000

# Backend (FastAPI) external port
BACKEND_PORT=8080

# IP address for external access (use your server IP in production)
IP_ADDR=localhost

# Public URL the browser calls for the backend API (baked into the frontend
# at build time, so a rebuild is needed after changing this).
# Local/LAN default: derived from IP_ADDR/BACKEND_PORT above.
# Behind danaul-caddy: https://emailsender.kdocai.com/api
#NEXT_PUBLIC_BACKEND_URL=https://emailsender.kdocai.com/api

# Origins allowed to call the backend (CORS).
# Local/LAN default: derived from IP_ADDR/FRONTEND_PORT above.
# Behind danaul-caddy, include the public https origin:
#ALLOWED_ORIGIN_URLS=http://localhost:3000,http://127.0.0.1:3000,https://emailsender.kdocai.com
